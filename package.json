{
  "name": "nexusmind---the-problem-solving-network",
  "private": true,
  "version": "1.3.0",
  "description": "A collaborative platform where experts connect to solve challenges together",
  "type": "module",
  "author": "NexusMind Team",
  "license": "MIT",
  "homepage": "https://github.com/nexusmind/nexusmind---the-problem-solving-network#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexusmind/nexusmind---the-problem-solving-network.git"
  },
  "bugs": {
    "url": "https://github.com/nexusmind/nexusmind---the-problem-solving-network/issues"
  },
  "keywords": [
    "react",
    "typescript",
    "firebase",
    "collaboration",
    "problem-solving",
    "social-network",
    "expert-matching"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit --skipLibCheck",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "build:api": "cd backend && npm install",
    "dev:api": "cd backend && npm run dev",
    "build:full": "npm run build:api && npm run build",
    "vercel-build": "npm run build",
    "clean": "rm -rf dist node_modules/.vite",
    "analyze": "npm run build && npx vite-bundle-analyzer dist/stats.html"
  },
  "dependencies": {
    "firebase": "^12.9.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-bundle-analyzer": "^0.7.0"
  }
}
